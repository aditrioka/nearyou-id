# Copy to dev/.env and fill in. dev/.env is gitignored.

# Postgres (consumed by docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nearyou_dev

# Backend DB connection (consumed by Ktor + Flyway)
DB_URL=jdbc:postgresql://localhost:5433/nearyou_dev
DB_USER=postgres
DB_PASSWORD=postgres

# Ktor environment selector
KTOR_ENV=development

# RSA key for access-token signing.
# Generate with: dev/scripts/generate-rsa-keypair.sh
# Value is base64-encoded PKCS#8 PEM private key.
KTOR_RSA_PRIVATE_KEY=

# HMAC secret for Supabase realtime tokens (HS256).
# Use any 32-byte random base64 in dev: openssl rand -base64 32
SUPABASE_JWT_SECRET=

# Comma-separated allow-lists for ID-token aud claims.
# Empty until Google/Apple OAuth client IDs are provisioned.
GOOGLE_CLIENT_IDS=
APPLE_BUNDLE_IDS=

# Copy to dev/.env and fill in. dev/.env is gitignored.

# Postgres (consumed by docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nearyou_dev

# Backend DB connection (consumed by Ktor + Flyway)
DB_URL=jdbc:postgresql://localhost:5433/nearyou_dev
DB_USER=postgres
DB_PASSWORD=postgres

# Ktor environment selector
KTOR_ENV=development

# RSA key for access-token signing.
# Generate with: dev/scripts/generate-rsa-keypair.sh
# Value is base64-encoded PKCS#8 PEM private key.
KTOR_RSA_PRIVATE_KEY=

# HMAC secret for Supabase realtime tokens (HS256).
# Use any 32-byte random base64 in dev: openssl rand -base64 32
SUPABASE_JWT_SECRET=

# Comma-separated allow-lists for ID-token aud claims.
# Empty until Google/Apple OAuth client IDs are provisioned.
GOOGLE_CLIENT_IDS=
APPLE_BUNDLE_IDS=

# HMAC key for deterministic invite-code derivation (HMAC-SHA256).
# 32 raw random bytes, base64-encoded. Generate with: openssl rand -base64 32
# Resolved via SecretResolver under the name "invite-code-secret".
INVITE_CODE_SECRET=

# HMAC key for coordinate jitter (HMAC-SHA256) — docs/05-Implementation.md § Coordinate Fuzzing.
# 32 raw random bytes, base64-encoded. Generate with: openssl rand -base64 32
# Resolved via SecretResolver under the name "jitter-secret".
# Rotation is an incident-only operation (docs/08 Decision 20): rotating
# requires re-fuzzing every posts row via a Cloud Run Jobs batch.
JITTER_SECRET=
